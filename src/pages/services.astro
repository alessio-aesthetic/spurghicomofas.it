---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Servizi di spurgo a Como',
  description: 'Tutti i servizi di Spurghi Como Fast: disotturazioni, autospurgo, videoispezioni, fosse biologiche, pozzetti, caditoie e pronto intervento.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Servizi"
    title="Servizi di spurgo a Como per case, condomini e attività"
    subtitle="Ogni pagina servizio spiega quando chiamare, come interveniamo e quali vantaggi offre un intervento tecnico rispetto ai tentativi improvvisati."
    actions={[{ variant: 'primary', text: 'Chiama 031 668 0329', href: 'tel:0316680329' }]}
    image={{ src: '/images/spurghi/manutenzione-fognature.png', alt: 'Servizi di spurgo e manutenzione fognature' }}
  />
  <Features2 title="Scegli il servizio" subtitle="Apri la scheda più vicina al problema che stai riscontrando." columns={3} items={[
  {
    "title": "Disotturazione WC a Como",
    "description": "WC bloccato, acqua che risale dal sanitario, bagno inutilizzabile e cattivi odori improvvisi.",
    "icon": "tabler:toilet-paper",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/disotturazione-wc/"
    }
  },
  {
    "title": "Disotturazione Lavandini a Como",
    "description": "Lavandini lenti, scarichi cucina ostruiti da grassi, sapone, calcare e residui.",
    "icon": "tabler:droplet",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/disotturazione-lavandini/"
    }
  },
  {
    "title": "Disotturazione Docce e Vasche a Como",
    "description": "Acqua che ristagna in doccia, vasche lente, pilette bloccate e odori persistenti.",
    "icon": "tabler:bath",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/disotturazione-docce-vasche/"
    }
  },
  {
    "title": "Disotturazione Colonne di Scarico a Como",
    "description": "Più scarichi lenti nello stesso edificio, rumori nella colonna e reflussi dai piani bassi.",
    "icon": "tabler:building",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/disotturazione-colonne-scarico/"
    }
  },
  {
    "title": "Videoispezioni Fognature a Como",
    "description": "Blocchi ricorrenti, sospette rotture, radici, cedimenti o punti interni da controllare.",
    "icon": "tabler:camera-search",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/videoispezioni-fognature/"
    }
  },
  {
    "title": "Spurgo Fosse Biologiche a Como",
    "description": "Fosse piene, odori persistenti, scarichi lenti e necessità di svuotamento programmato.",
    "icon": "tabler:truck",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/spurgo-fosse-biologiche/"
    }
  },
  {
    "title": "Spurgo Pozzi Neri a Como",
    "description": "Pozzi neri pieni, odori forti, impianti che ricevono lentamente e reflui da aspirare.",
    "icon": "tabler:recycle",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/spurgo-pozzi-neri/"
    }
  },
  {
    "title": "Pulizia Pozzetti Stradali a Como",
    "description": "Pozzetti pieni, acqua ferma dopo la pioggia, depositi di terra, sabbia e foglie.",
    "icon": "tabler:road",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/pulizia-pozzetti-stradali/"
    }
  },
  {
    "title": "Pulizia Caditoie e Pluviali a Como",
    "description": "Caditoie o pluviali ostruiti, ristagni, rigurgiti durante temporali e griglie sporche.",
    "icon": "tabler:cloud-rain",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/pulizia-caditoie-pluviali/"
    }
  },
  {
    "title": "Bonifica Allagamenti a Como",
    "description": "Cantine, box, locali tecnici e cortili invasi da acqua o reflui dopo un guasto.",
    "icon": "tabler:bucket",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/bonifica-allagamenti/"
    }
  },
  {
    "title": "Manutenzione Fognature a Como",
    "description": "Impianti che rallentano spesso, pozzetti da controllare e reti private da mantenere pulite.",
    "icon": "tabler:settings-check",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/manutenzione-fognature/"
    }
  },
  {
    "title": "Pronto Intervento Spurghi 24H a Como",
    "description": "Emergenze improvvise, reflussi, scarichi inutilizzabili e problemi che non possono aspettare.",
    "icon": "tabler:clock-24",
    "callToAction": {
      "text": "Apri servizio",
      "href": "/servizi/pronto-intervento-24h/"
    }
  }
]} />
  <CallToAction title="Non sai quale servizio serve?" subtitle="Descrivici il problema al telefono: ti aiutiamo a capire il tipo di intervento più adatto." actions={[{ variant: 'primary', text: 'Chiama ora', href: 'tel:0316680329' }]} />
</Layout>
